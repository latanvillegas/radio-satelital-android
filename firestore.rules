rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function adminEmail() {
      return "alv.oficial123@gmail.com";
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == adminEmail();
    }

    // Radios enviadas por usuarios para moderacion
    match /submitted_radios/{radioId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "pending";
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Radios publicas visibles para todos
    match /public_radios/{radioId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Conteo en tiempo real de oyentes por stream
    match /radio_live_listeners/{listenerDocId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }
  }
}
